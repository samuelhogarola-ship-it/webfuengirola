FROM node:22-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci --ignore-scripts
COPY . .
RUN npm run build:all
RUN mkdir -p /out
RUN cp -R \
  /app/index.html \
  /app/style.css \
  /app/script.js \
  /app/contact-form.js \
  /app/cookie-banner-core.css \
  /app/cookie-banner-core.js \
  /app/google-analytics-core.js \
  /app/legal-core.js \
  /app/legal-page.js \
  /app/legal.html \
  /app/robots.txt \
  /app/sitemap.xml \
  /app/favicon.png \
  /app/favicon.webp \
  /app/apple-touch-icon.png \
  /app/site.webmanifest \
  /app/blog \
  /app/casos \
  /app/como-trabajamos \
  /app/contacto \
  /app/img \
  /app/portfolio \
  /app/portfolio.html \
  /app/productos \
  /app/proceso.html \
  /app/recursos \
  /app/servicios \
  /app/servicios.html \
  /app/sobre-nosotros \
  /out/

FROM nginx:alpine
COPY --from=builder /out/ /usr/share/nginx/html/
COPY nginx/default.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
